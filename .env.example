# === Required: Slack ===
SLACK_BOT_TOKEN="xoxb-your-slack-bot-token"
SLACK_SIGNING_SECRET="your-slack-signing-secret"

# === Required: Salesforce Connected App (client_credentials) ===
SF_CLIENT_ID="your-salesforce-consumer-key"
SF_CLIENT_SECRET="your-salesforce-consumer-secret"

# === Required: Google Cloud / Vertex AI ===
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT="your-gcp-project"
GOOGLE_CLOUD_LOCATION="global"

# === Optional: Access Control ===
ALLOWED_SLACK_WORKSPACE="T0123456789"
ALLOWED_SLACK_USERS="U01AB2CD3EF,U04XY5ZW6GH"

# === Optional: Salesforce ===
SF_LOGIN_URL="https://login.salesforce.com"
SF_API_VERSION="v66.0"

# === Optional: Agent / Model ===
MODEL_NAME="gemini-3.1-flash-lite-preview"

APP_NAME="salesforce-agent"

# === Optional: Slack Reactions ===
REACTION_PROCESSING="eyes"
REACTION_COMPLETED="white_check_mark"

# === Optional: Cloud Run Deployment ===
CLOUD_RUN_LOCATION="us-central1"
